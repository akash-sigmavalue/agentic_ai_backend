  AND project_latitude IS NOT NULL
  AND project_longitude IS NOT NULL
  AND property_type IN ('Office')
GROUP BY
  project_id,
  project_name,
  project_latitude,
  project_longitude,
  location_name,
  country_name,
  property_type,
  transaction_category
