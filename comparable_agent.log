    least(1, greatest(-1,
      cos(radians(19.1153798)) * cos(radians(project_latitude)) *
      cos(radians(project_longitude) - radians(72.9091436)) +
      sin(radians(19.1153798)) * sin(radians(project_latitude))
    ))
  ) <= 2.0
ORDER BY
  distance ASC
