      cos(radians(18.5395129)) * cos(radians(t.project_latitude)) *
      cos(radians(t.project_longitude) - radians(73.94636849999999)) +
      sin(radians(18.5395129)) * sin(radians(t.project_latitude))
    ))
  ) <= 2.0
ORDER BY
  distance ASC
