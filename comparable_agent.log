  project_id,
  project_name,
  project_latitude,
  project_longitude,
  location_name,
  country_name,
  property_type,
  transaction_category AS property_category,
  ROUND(
    6371 * acos(
      least(1, greatest(-1,
        cos(radians(18.5395129)) * cos(radians(project_latitude)) *
        cos(radians(project_longitude) - radians(73.94636849999999)) +
