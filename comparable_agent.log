  GROUP BY
    project_id,
    project_name,
    project_latitude,
    project_longitude,
    location_name,
    country_name,
    property_type,
    transaction_category
)
SELECT
  project_id AS project_id,
  project_name AS project_name,
  lat,
  long,
  location AS location,
  country AS country,
  property_type,
  property_category,
  ROUND(raw_distance::numeric, 2) AS distance,
  total_transaction_count
FROM project_stats
WHERE raw_distance <= 3.0
ORDER BY distance ASC;
