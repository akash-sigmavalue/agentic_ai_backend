  project_id,
  project_name,
  project_latitude AS lat,
  project_longitude AS long,
  location_name AS location,
  country_name AS country,
  property_type,
  transaction_category AS property_category,
  ROUND(
    6371 * acos(
      least(1, greatest(-1,
        cos(radians(18.5753902)) * cos(radians(project_latitude)) *
        cos(radians(project_longitude) - radians(73.8770752)) +
        sin(radians(18.5753902)) * sin(radians(project_latitude))
      ))
    )::numeric,
    2
  ) AS distance,
  COUNT(*) AS total_transaction_count
FROM transactions
WHERE
  project_latitude IS NOT NULL
  AND project_longitude IS NOT NULL
  AND agreement_price >= 1
  AND transaction_category IN ('Sale')
  AND property_type IN ('Office')
GROUP BY
  project_id,
  project_name,
  project_latitude,
  project_longitude,
  location_name,
  country_name,
  property_type,
  transaction_category
HAVING
  6371 * acos(
    least(1, greatest(-1,
      cos(radians(18.5753902)) * cos(radians(project_latitude)) *
      cos(radians(project_longitude) - radians(73.8770752)) +
      sin(radians(18.5753902)) * sin(radians(project_latitude))
    ))
  ) <= 3.0
ORDER BY
  distance ASC
