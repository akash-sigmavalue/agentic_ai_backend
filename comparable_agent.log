2026-05-21 17:25:17,431 | INFO | [iter=0] EXECUTE — WITH radius_search AS (
  SELECT
    project_id,
    project_name,
    location_name,
    country_name,
    property_type,
    transaction_category,
    project_latitude,
    project_longitude,
    6371 * acos(
      least(1, greatest(-1,
        cos(radians(18.5395129)) * cos(radians(project_latitude)) *
        cos(radians(project_longitude) - radians(73.94636849999999)) +
        sin(radians(18.5395129)) * sin(radians(project_latitude))
      ))
    ) AS distance_km
  FROM transactions
  WHERE
    agreement_price >= 1
    AND project_latitude IS NOT NULL
    AND project_longitude IS NOT NULL
    AND transaction_category IN ('Sale')
    AND property_type IN ('Flat')
)
SELECT
  project_id AS project_id,
  project_name AS project_name,
  project_latitude AS lat,
  project_longitude AS long,
  location_name AS location,
  country_name AS country,
  property_type AS property_type,
  transaction_category AS property_category,
  ROUND(distance_km::numeric, 2) AS distance,
  COUNT(*) AS total_transaction_count
FROM radius_search
WHERE distance_km <= 2.0
GROUP BY
  project_id,
  project_name,
  project_latitude,
  project_longitude,
  location_name,
  country_name,
  property_type,
  transaction_category,
  distance_km
ORDER BY distance_km ASC
