  project_latitude IS NOT NULL
  AND project_longitude IS NOT NULL
  AND ROUND(
    6371 * acos(
      least(1, greatest(-1,
        cos(radians(18.5529376)) * cos(radians(project_latitude)) *
        cos(radians(project_longitude) - radians(73.7589327)) +
        sin(radians(18.5529376)) * sin(radians(project_latitude))
