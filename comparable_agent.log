      ))
    )::numeric,
    2
  ) AS distance,
  COUNT(*) AS total_transaction_count
FROM transactions t
WHERE
  t.agreement_price >= 1
  AND t.project_latitude IS NOT NULL
  AND t.project_longitude IS NOT NULL
  AND t.transaction_category IN ('Sale')
  AND t.property_type IN ('Flat')
GROUP BY
  t.project_id,
  t.project_name,
  t.project_latitude,
  t.project_longitude,
  t.location_name,
  t.country_name,
  t.property_type,
  t.transaction_category
HAVING
  6371 * acos(
    least(1, greatest(-1,
      cos(radians(18.5395129)) * cos(radians(t.project_latitude)) *
      cos(radians(t.project_longitude) - radians(73.94636849999999)) +
      sin(radians(18.5395129)) * sin(radians(t.project_latitude))
    ))
  ) <= 3.0
ORDER BY
  distance ASC
