  t.project_id,
  t.project_name,
  t.project_latitude AS lat,
  t.project_longitude AS long,
  t.location_name AS location,
  t.country_name,
  t.property_type,
  t.transaction_category AS property_category,
  ROUND(
    6371 * acos(
      least(1, greatest(-1,
        cos(radians(18.5395129)) * cos(radians(t.project_latitude)) *
